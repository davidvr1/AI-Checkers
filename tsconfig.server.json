{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true
  },
  // Only the server entry; TypeScript pulls in the pure game/protocol modules it
  // imports automatically. The DOM-using client files (useOnlineGame, screens)
  // are intentionally NOT here -- they are typechecked by the app's tsconfig.
  "include": ["server"]
}
